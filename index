<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Spider Clock</title>
<link rel="stylesheet" href="style.css">
</head>
<body>

<div class="clock">

    <div class="number n12">12</div>
    <div class="number n1">1</div>
    <div class="number n2">2</div>
    <div class="number n3">3</div>
    <div class="number n4">4</div>
    <div class="number n5">5</div>
    <div class="number n6">6</div>
    <div class="number n7">7</div>
    <div class="number n8">8</div>
    <div class="number n9">9</div>
    <div class="number n10">10</div>
    <div class="number n11">11</div>

    <!-- Gear 1 -->
    <svg class="gear gear1" viewBox="0 0 200 200">
        <polygon points="
        100,10 115,20 135,15 145,35
        165,35 170,55 190,65 180,85
        190,100 180,115 190,135 170,145
        165,165 145,165 135,185 115,180
        100,190 85,180 65,185 55,165
        35,165 30,145 10,135 20,115
        10,100 20,85 10,65 30,55
        35,35 55,35 65,15 85,20"
        fill="none"
        stroke="#ffb52e"
        stroke-width="5"/>

        <circle cx="100" cy="100" r="45"
        fill="none"
        stroke="#ffb52e"
        stroke-width="5"/>

        <circle cx="100" cy="100" r="12"
        fill="#ffb52e"/>
    </svg>

    <!-- Gear 2 -->
    <svg class="gear gear2" viewBox="0 0 200 200">
        <polygon points="
        100,10 115,20 135,15 145,35
        165,35 170,55 190,65 180,85
        190,100 180,115 190,135 170,145
        165,165 145,165 135,185 115,180
        100,190 85,180 65,185 55,165
        35,165 30,145 10,135 20,115
        10,100 20,85 10,65 30,55
        35,35 55,35 65,15 85,20"
        fill="none"
        stroke="#ffb52e"
        stroke-width="5"/>

        <circle cx="100" cy="100" r="45"
        fill="none"
        stroke="#ffb52e"
        stroke-width="5"/>

        <circle cx="100" cy="100" r="12"
        fill="#ffb52e"/>
    </svg>

    <!-- Gear 3 -->
    <svg class="gear gear3" viewBox="0 0 200 200">
        <polygon points="
        100,10 115,20 135,15 145,35
        165,35 170,55 190,65 180,85
        190,100 180,115 190,135 170,145
        165,165 145,165 135,185 115,180
        100,190 85,180 65,185 55,165
        35,165 30,145 10,135 20,115
        10,100 20,85 10,65 30,55
        35,35 55,35 65,15 85,20"
        fill="none"
        stroke="#ffb52e"
        stroke-width="5"/>

        <circle cx="100" cy="100" r="45"
        fill="none"
        stroke="#ffb52e"
        stroke-width="5"/>

        <circle cx="100" cy="100" r="12"
        fill="#ffb52e"/>
    </svg>

    <!-- Spider -->
    <svg class="spider" viewBox="0 0 200 200">

        <ellipse cx="100" cy="120"
        rx="30" ry="40"
        fill="#ffb52e"/>

        <circle cx="100" cy="75"
        r="20"
        fill="#ffb52e"/>

        <line x1="80" y1="90" x2="30" y2="50" stroke="#ffb52e" stroke-width="5"/>
        <line x1="80" y1="100" x2="25" y2="85" stroke="#ffb52e" stroke-width="5"/>
        <line x1="80" y1="110" x2="25" y2="125" stroke="#ffb52e" stroke-width="5"/>
        <line x1="80" y1="120" x2="35" y2="160" stroke="#ffb52e" stroke-width="5"/>

        <line x1="120" y1="90" x2="170" y2="50" stroke="#ffb52e" stroke-width="5"/>
        <line x1="120" y1="100" x2="175" y2="85" stroke="#ffb52e" stroke-width="5"/>
        <line x1="120" y1="110" x2="175" y2="125" stroke="#ffb52e" stroke-width="5"/>
        <line x1="120" y1="120" x2="165" y2="160" stroke="#ffb52e" stroke-width="5"/>

    </svg>

    <div id="hour" class="hand hour"></div>
    <div id="minute" class="hand minute"></div>
    <div id="second" class="hand second"></div>

</div>

<script src="script.js"></script>

</body>
</html>
